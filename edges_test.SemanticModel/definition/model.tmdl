model Model
	culture: en-AU
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-AU
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["EDGE","FROM_NODE","TO_NODE"]

annotation PBI_ProTooling = ["TMDLView_Desktop","DevMode","DaxQueryView_Desktop"]

ref table EDGE
ref table FROM_NODE
ref table TO_NODE

ref cultureInfo en-AU

